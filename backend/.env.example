# Copy to backend/.env and fill in values — never commit .env

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/blackspire
SECRET_KEY=generate-a-long-random-secret
EMAIL_FROM=blackspirereality@gmail.com

# Email (choose one transport)
GMAIL_APP_PASSWORD=
GOOGLE_CREDENTIALS_BASE64=
GOOGLE_TOKEN_BASE64=

# OAuth login (optional)
GOOGLE_CLIENT_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# First-admin bootstrap (Render only, remove password after first login)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Platform Administrator
BOOTSTRAP_ADMIN_ROLE=admin
