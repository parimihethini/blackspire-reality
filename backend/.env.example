# ─── Blackspire Backend — Environment Variables Template ─────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file. It is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string
DEBUG=false
AUTH_DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection URL. URL-encode any special chars in the password.
# Example: postgresql://postgres:P%40ssword@127.0.0.1:5432/blackspire
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (Gmail OAuth2 service account) ─────────────────────────────────────
EMAIL_FROM=your-email@gmail.com

# ── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of extra frontend origins (appended to the default list).
FRONTEND_ORIGINS=https://your-app.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=60/minute

# ── Test / Script Credentials ────────────────────────────────────────────────
# Used by local verification and debug scripts (verify_*.py, full_test.py, etc.)
# DO NOT use real production credentials here — use dedicated test accounts.
TEST_ADMIN_EMAIL=testadmin@example.com
TEST_ADMIN_PASSWORD=replace-with-your-test-admin-password

TEST_SUPER_ADMIN_EMAIL=superadmin@example.com
TEST_SUPER_ADMIN_PASSWORD=replace-with-your-super-admin-password

TEST_SELLER_EMAIL=testseller@example.com
TEST_SELLER_PASSWORD=replace-with-your-test-seller-password
